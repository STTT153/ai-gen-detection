# Copy this file to .env and fill in values as needed.
# None of these are required — defaults work for local development.

# --- Web server ---

# HTTP port for the Flask dev server (python web/app.py).
# Gunicorn ignores this; set the bind address in web/gunicorn.conf.py instead.
PORT=8000

# Path to the SwinSeg checkpoint. Defaults to model/checkpoints/best_seg_ft.pth.
# SWINSEG_CKPT=model/checkpoints/best_seg_ft.pth

# --- LLM (optional) ---
# Credentials are stored in web/config.json (gitignored) and editable via the
# Settings panel in the UI. You can also pre-populate the file from these vars
# by running:
#   python -c "
#   import json, os, pathlib
#   cfg = {'api_key': os.environ['LLM_API_KEY'],
#          'base_url': os.environ.get('LLM_BASE_URL', 'https://coding.dashscope.aliyuncs.com/apps/anthropic'),
#          'model': os.environ.get('LLM_MODEL', 'qwen3-coder-plus')}
#   pathlib.Path('web/config.json').write_text(json.dumps(cfg, indent=2))
#   "
#
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
# LLM_MODEL=qwen3-coder-plus
